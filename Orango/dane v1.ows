		<properties node_id="4" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xc0\x00\x00\x00\x82\x00\x00\x05\xc5\x00\x00\x03\t\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08', 'scriptLibrary': [], 'scriptText': 'import numpy as np\nfrom Orange.data import ContinuousVariable\n\n# 1. Tworzymy zmienną id2\nnew_var = ContinuousVariable("id2")\n\n# 2. Tworzymy płaską listę wartości (bez reshape)\nvalues = np.arange(1, len(in_data) + 1)\n\n# 3. Dodajemy kolumnę do metadanych\nout_data = in_data.add_column(new_var, values, to_metas=True)\n', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
