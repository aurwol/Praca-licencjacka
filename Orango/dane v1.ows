		<properties node_id="52" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xc0\x00\x00\x00\x82\x00\x00\x05\xc5\x00\x00\x03\t\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08', 'scriptLibrary': [], 'scriptText': 'import Orange\nimport re\nfrom Orange.data import Domain, ContinuousVariable\n\ntry:\n    from langdetect import detect, DetectorFactory\n    DetectorFactory.seed = 0\n    USE_LANGDETECT = True\nexcept ImportError:\n    USE_LANGDETECT = False\n\n# Rozbudowana sieć bezpieczeństwa: typowo angielskie słówka, skróty i slang internetowy\nENG_SAFETY_NET = {\n    \'the\', \'be\', \'to\', \'of\', \'and\', \'a\', \'in\', \'that\', \'have\', \'i\', \'it\', \'for\', \'on\', \'with\',\n    \'he\', \'as\', \'you\', \'do\', \'at\', \'this\', \'but\', \'his\', \'by\', \'from\', \'they\', \'we\', \'say\',\n    \'just\', \'fyi\', \'ai\', \'isnt\', \'dont\', \'cant\', \'not\', \'are\', \'am\', \'my\', \'your\', \'me\', \'im\',\n    \'cool\', \'good\', \'thanks\', \'thank\', \'lol\', \'lmao\', \'wow\', \'yeah\', \'yes\', \'no\', \'ok\', \'okay\',\n    \'u\', \'r\', \'hi\', \'hello\', \'pls\', \'please\', \'like\', \'get\', \'was\', \'so\', \'up\', \'out\', \'now\'\n}\n\ndef clean_for_detection(text):\n    """Czyści tekst tylko na potrzeby rozpoznawania języka"""\n    # 1. Usuń wzmianki (@user) i hashtagi (#tag)\n    text = re.sub(r\'[@#]\\w+\', \'\', text)\n    # 2. Usuń linki URL\n    text = re.sub(r\'http\\S+\', \'\', text)\n    # 3. Usuń emotki i znaki specjalne (zostaw tylko litery łacińskie i spacje)\n    text = re.sub(r\'[^a-zA-Z\\s]\', \'\', text)\n    # 4. Zmień wielokrotne spacje w jedną\n    text = re.sub(r\'\\s+\', \' \', text).strip().lower()\n    return text\n\nout_data = None\n\nif in_data is not None:\n    text_vars = [v for v in in_data.domain.metas if v.is_string] + \\\n                [v for v in in_data.domain.attributes if v.is_string]\n    \n    if text_vars:\n        text_attr = text_vars[0]\n        is_eng_var = ContinuousVariable("Is_English")\n        \n        new_domain = Domain(\n            in_data.domain.attributes, \n            in_data.domain.class_vars, \n            metas=in_data.domain.metas + (is_eng_var,)\n        )\n        \n        out_data = Orange.data.Table(new_domain, in_data)\n        \n        for row in out_data:\n            original_text = str(row[text_attr]).strip()\n            is_english = 0  # Domyślnie nie-angielski\n            \n            if original_text and original_text != "?":\n                # Oczyszczamy tekst do analizy (usuwamy @, #, emotki)\n                cleaned = clean_for_detection(original_text)\n                words = cleaned.split()\n                \n                # REGUŁA AWARYJNA DLA EMOTEK / SAMYCH NICKÓW:\n                # Jeśli po oczyszczeniu tekstu nic nie zostało (np. komentarz to same emotki albo tylko "@user"),\n                # oznaczamy jako 1 (angielski), żeby NIE tracić danych w ciemno.\n                if not words:\n                    is_english = 1\n                else:\n                    # Liczymy ile słów pasuje do naszej angielskiej sieci bezpieczeństwa\n                    safety_matches = sum(1 for w in words if w in ENG_SAFETY_NET)\n                    \n                    # Jeśli tekst zawiera super-popularne angielskie słowa/slang,\n                    # od razu uznajemy go za angielski (omijamy surowy langdetect)\n                    if safety_matches &gt;= 1 and (len(words) &lt;= 4 or (safety_matches / len(words)) &gt;= 0.15):\n                        is_english = 1\n                    elif USE_LANGDETECT:\n                        try:\n                            # Jeśli sieć bezpieczeństwa nie pomogła, pytamy langdetect\n                            if detect(cleaned) == \'en\':\n                                is_english = 1\n                        except Exception:\n                            pass\n            \n            row[is_eng_var] = is_english\n            \n        print("Filtrowanie zakończone. Sprawdź wyniki w Data Table!")\n    else:\n        out_data = in_data', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
