		<properties node_id="44" format="literal">{'controlAreaVisible': True, 'currentScriptIndex': 0, 'savedWidgetGeometry': b'\x01\xd9\xd0\xcb\x00\x03\x00\x00\x00\x00\x01\xc0\x00\x00\x00\x82\x00\x00\x05\xc5\x00\x00\x03\t\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08\x00\x00\x00\x00\x00\x00\x00\x00\x07\x80\x00\x00\x01\xc1\x00\x00\x00\xa1\x00\x00\x05\xc4\x00\x00\x03\x08', 'scriptLibrary': [], 'scriptText': 'import Orange\n\nout_data = None\n\nif in_data is not None:\n    # Sprawdzamy, czy dane to obiekt typu Corpus posiadający przetworzone tokeny\n    if hasattr(in_data, "tokens") and in_data.tokens is not None:\n        valid_indices = []\n        \n        for idx, doc_tokens in enumerate(in_data.tokens):\n            # Sprawdzamy, czy lista tokenów nie jest pusta i czy zawiera realne słowa\n            # (odrzucamy puste listy [] oraz tokeny będące tylko spacjami)\n            if doc_tokens and any(str(t).strip() for t in doc_tokens):\n                valid_indices.append(idx)\n        \n        # Slicing [valid_indices] na obiekcie typu Corpus w Orange \n        # automatycznie i poprawnie odfiltruje zarówno wiersze, jak i przypisane do nich tokeny\n        out_data = in_data[valid_indices]\n        \n        print(f"Wierszy przed: {len(in_data)}")\n        print(f"Wierszy po: {len(out_data)}")\n    else:\n        print("BŁĄD: Skrypt nie znalazł tokenów. Upewnij się, że widget jest połączony ZA Preprocess Text!")\n        out_data = in_data', 'splitterState': b'\x00\x00\x00\xff\x00\x00\x00\x01\x00\x00\x00\x02\x00\x00\x00\x9f\x00\x00\x00`\x01\xff\xff\xff\xff\x01\x00\x00\x00\x02\x00', 'vimModeEnabled': False, '__version__': 2}</properties>
